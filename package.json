{
  "name": "moziwatch",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format:check": "prettier --check .",
    "lint": "eslint . --ignore-pattern .next",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "node --env-file-if-exists=.env.local --import tsx db/migrate-test.ts && node --env-file-if-exists=.env.local node_modules/vitest/vitest.mjs run tests/report-concurrency.integration.test.ts",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file-if-exists=.env.local --import tsx db/migrate.ts",
    "db:seed": "node --env-file-if-exists=.env.local --import tsx db/seed.ts",
    "forecast:run": "node --env-file-if-exists=.env.local --import tsx worker/run-forecast.ts",
    "forecast:scheduler": "node --env-file-if-exists=.env.local --import tsx worker/scheduler.ts",
    "model:train": "tsx worker/train-model.ts"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@protomaps/basemaps": "^5.7.2",
    "better-auth": "^1.6.23",
    "csv-parse": "^7.0.1",
    "drizzle-orm": "0.45.2",
    "maplibre-gl": "^5.24.0",
    "nanoid": "^6.0.0",
    "next": "16.2.6",
    "node-cron": "^4.6.0",
    "pmtiles": "^4.4.1",
    "postgres": "^3.4.9",
    "prettier": "^3.6.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "resend": "^6.17.2",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/node-cron": "^3.0.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  },
  "type": "module"
}
