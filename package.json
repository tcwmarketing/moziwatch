{
  "name": "moziwatch",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "format:check": "prettier --check .",
    "lint": "eslint . --ignore-pattern .next",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "node --env-file-if-exists=.env.local --import tsx db/migrate-test.ts && node --env-file-if-exists=.env.local node_modules/vitest/vitest.mjs run tests/report-concurrency.integration.test.ts tests/location-ingestion.integration.test.ts",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file-if-exists=.env.local --import tsx db/migrate.ts",
    "db:seed": "node --env-file-if-exists=.env.local --import tsx db/seed.ts",
    "admin:ensure": "node --env-file-if-exists=.env.local --import tsx worker/ensure-admin.ts",
    "prelaunch:audit": "node --env-file-if-exists=.env.local --import tsx worker/prelaunch-audit.ts",
    "prelaunch:optimize": "node --env-file-if-exists=.env.local --import tsx worker/optimize-database.ts",
    "prelaunch:reset-forecast-storage": "node --env-file-if-exists=.env.local --import tsx worker/reset-prelaunch-forecast-storage.ts",
    "forecast:run": "node --env-file-if-exists=.env.local --import tsx worker/run-forecast.ts",
    "forecast:cleanup": "node --env-file-if-exists=.env.local --import tsx worker/cleanup-forecast-retention.ts",
    "forecast:status": "node --env-file-if-exists=.env.local --import tsx worker/forecast-status.ts",
    "reports:summarize": "node --env-file-if-exists=.env.local --import tsx worker/run-report-summaries.ts",
    "products:sync-images": "node --import tsx worker/sync-product-images.ts",
    "forecast:run-monthly": "node --env-file-if-exists=.env.local --import tsx worker/run-monthly-outlooks.ts",
    "habitat:export": "node --env-file-if-exists=.env.local --import tsx worker/habitat/export-campgrounds.ts",
    "habitat:export-major": "node --env-file-if-exists=.env.local --import tsx worker/habitat/export-campgrounds.ts --major-only",
    "habitat:export-minor": "node --env-file-if-exists=.env.local --import tsx worker/habitat/export-campgrounds.ts --minor-only",
    "habitat:process-major": "python worker/habitat/process-north-america.py --fast",
    "habitat:process-minor": "python worker/habitat/process-north-america.py --minor-fast",
    "habitat:process": "python worker/habitat/process-north-america.py",
    "habitat:publish": "node --env-file-if-exists=.env.local --import tsx worker/process-habitat.ts",
    "habitat:verify": "node --env-file-if-exists=.env.local --import tsx worker/habitat/verify-coverage.ts",
    "forecast:backfill-weather": "node --env-file-if-exists=.env.local --import tsx worker/backfill-weather-history.ts",
    "forecast:compare-shadow": "node --env-file-if-exists=.env.local --import tsx worker/compare-forecast-shadow.ts",
    "locations:import:osm": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts osm",
    "locations:import:overture-ca": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts overture-ca",
    "locations:import:overture-us": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts overture-us",
    "locations:bootstrap:overture-ca": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts overture-bootstrap-ca",
    "locations:bootstrap:overture-us": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts overture-bootstrap-us",
    "locations:import:ridb": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts ridb",
    "locations:bootstrap:ridb": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts ridb-bootstrap",
    "locations:import:nps": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts nps",
    "locations:import:usfs": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts usfs",
    "locations:bootstrap:usfs": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts usfs-bootstrap",
    "locations:import:parks-canada": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts parks-canada",
    "locations:import:quebec": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts quebec",
    "locations:import:nova-scotia": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts nova-scotia",
    "locations:import:bc": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts bc",
    "locations:import:bc-parks": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts bc-parks",
    "locations:merge-candidates": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts candidates",
    "locations:refresh": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts refresh",
    "locations:import:all": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts all",
    "locations:reconcile": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts reconcile",
    "locations:refresh:weekly": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts weekly",
    "locations:refresh:monthly": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts monthly",
    "locations:scheduler": "node --env-file-if-exists=.env.local --import tsx worker/locations/scheduler.ts",
    "locations:import:status": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts status",
    "locations:audit": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts audit",
    "locations:audit-coverage": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts coverage-gaps",
    "locations:fill-gaps:osm": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts fill-gaps-osm",
    "locations:duplicates": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts duplicates",
    "locations:deletion-candidates": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts deletions",
    "locations:cleanup:overture": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts cleanup-overture",
    "locations:cleanup:storage": "node --env-file-if-exists=.env.local --import tsx worker/locations/storage-cleanup.ts",
    "locations:cleanup:names": "node --env-file-if-exists=.env.local --import tsx worker/locations/name-cleanup.ts",
    "locations:merge": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts merge",
    "locations:merge-automatic": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts merge-automatic",
    "locations:enrich-capacity": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts enrich-capacity",
    "locations:enrich-localities": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts enrich-localities",
    "locations:verify:saskatchewan": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts verify-saskatchewan",
    "locations:verify:overture": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts verify-overture",
    "locations:verify": "node --env-file-if-exists=.env.local --import tsx worker/locations/cli.ts verify"
  },
  "dependencies": {
    "@fontsource-variable/montserrat": "^5.2.8",
    "@node-rs/argon2": "^2.0.2",
    "@protomaps/basemaps": "^5.7.2",
    "better-auth": "^1.6.23",
    "csv-parse": "^7.0.1",
    "drizzle-orm": "0.45.2",
    "maplibre-gl": "^5.24.0",
    "nanoid": "^6.0.0",
    "next": "16.2.6",
    "node-cron": "^4.6.0",
    "pmtiles": "^4.4.1",
    "postgres": "^3.4.9",
    "prettier": "^3.6.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "resend": "^6.17.2",
    "server-only": "^0.0.1",
    "stripe": "^22.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/node-cron": "^3.0.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  },
  "type": "module"
}
