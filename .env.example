# Public product configuration
NEXT_PUBLIC_APP_NAME=Camp Signal
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Protomaps Hosted API. {key} is replaced at runtime.
NEXT_PUBLIC_BASEMAP_MODE=hosted
NEXT_PUBLIC_PROTOMAPS_STYLE_URL=https://api.protomaps.com/styles/v5/light/en.json?key={key}
NEXT_PUBLIC_PROTOMAPS_API_KEY=
# Future self-hosted option. Set BASEMAP_MODE=pmtiles and provide the URL.
NEXT_PUBLIC_PROTOMAPS_PMTILES_URL=

# PostgreSQL 16 with PostGIS
DATABASE_URL=postgresql://moziwatch:moziwatch@localhost:5432/moziwatch
# Recommended for Supabase migrations; may equal DATABASE_URL for local Docker.
DIRECT_DATABASE_URL=postgresql://moziwatch:moziwatch@localhost:5432/moziwatch
# Must be a separate disposable database, never either URL above.
TEST_DATABASE_URL=
TEST_DATABASE_DISPOSABLE=false

# Authentication and privacy. Generate separate random values of at least 32 bytes.
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000
IP_HASH_SECRET=replace-with-a-different-long-random-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Resend is optional locally. Verification and reset links are logged when unset.
RESEND_API_KEY=
RESEND_FROM=Camp Signal <no-reply@example.test>

# Forecast provider. Use api.open-meteo.com for non-commercial development only.
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
OPEN_METEO_API_KEY=
FORECAST_MODEL_PATH=./config/models/current.json
FORECAST_CRON=15 5 * * *
FORECAST_GRID_DEGREES=2.5
# Trusted proxy handling. Leave 0 unless the app is behind exactly this many proxies.
TRUST_PROXY_HOPS=0
REPORT_COMMENT_EDIT_HOURS=24
# Command-only: promotes an existing verified account during db:seed.
SEED_ADMIN_EMAIL=
BOT_PROTECTION_PROVIDER=none
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
