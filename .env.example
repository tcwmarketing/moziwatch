# Public product configuration
NEXT_PUBLIC_APP_NAME=MoziWatch
# Keep localhost for local development. Production must use https://moziwatch.com.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Protomaps Hosted API. {key} is replaced at runtime.
NEXT_PUBLIC_BASEMAP_MODE=hosted
NEXT_PUBLIC_PROTOMAPS_STYLE_URL=https://api.protomaps.com/styles/v5/light/en.json?key={key}
NEXT_PUBLIC_PROTOMAPS_API_KEY=
# Future self-hosted option. Set BASEMAP_MODE=pmtiles and provide the URL.
NEXT_PUBLIC_PROTOMAPS_PMTILES_URL=

# PostgreSQL 16 with PostGIS
DATABASE_URL=postgresql://moziwatch:moziwatch@localhost:5432/moziwatch
# Recommended for Supabase migrations; may equal DATABASE_URL for local Docker.
DIRECT_DATABASE_URL=postgresql://moziwatch:moziwatch@localhost:5432/moziwatch
# Must be a separate disposable database, never either URL above.
TEST_DATABASE_URL=
TEST_DATABASE_DISPOSABLE=false

# Authentication and privacy. Generate separate random values of at least 32 bytes.
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
# Keep localhost locally. Production must use https://moziwatch.com.
BETTER_AUTH_URL=http://localhost:3000
IP_HASH_SECRET=replace-with-a-different-long-random-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Resend is optional locally. Verification and reset links are logged when unset.
RESEND_API_KEY=
RESEND_FROM=MoziWatch <no-reply@example.test>
# Server-only inbox used for clean Contact Us notifications. Never prefix with NEXT_PUBLIC_.
CONTACT_RECIPIENT_EMAIL=

# Stripe-hosted one-time donations. Keep both keys server-only.
# Use an sk_test_ key and a whsec_ signing secret while STRIPE_MODE=test.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MODE=test
STRIPE_DONATION_CURRENCY=cad

# Forecast provider. Use api.open-meteo.com for non-commercial development only.
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1/archive
OPEN_METEO_SEASONAL_BASE_URL=https://seasonal-api.open-meteo.com/v1/seasonal
OPEN_METEO_API_KEY=
# Keep 1-3; one batch at a time is the rate-limit-friendly default.
FORECAST_WEATHER_CONCURRENCY=1
# Open-Meteo supports comma-separated coordinates in one request.
FORECAST_WEATHER_BATCH_SIZE=10
# Milliseconds between rich 60-day weather request groups.
FORECAST_WEATHER_GROUP_DELAY_MS=10000
# Bound each run so weekly backlog cannot overwhelm the database or provider.
FORECAST_TARGET_COUNT=5000
FORECAST_REGIONAL_GRID_DEGREES=0.75
MONTHLY_FORECAST_TARGET_COUNT=1500
MONTHLY_WEATHER_BATCH_DELAY_MS=4000
RIDB_API_KEY=
RIDB_BULK_FILE=
NPS_API_KEY=
RIDB_BASE_URL=https://ridb.recreation.gov/api/v1
NPS_BASE_URL=https://developer.nps.gov/api/v1
BC_RECREATION_ARCGIS_URL=https://delivery.maps.gov.bc.ca/arcgis/rest/services/whse/bcgw_pub_whse_forest_tenure/MapServer/13
BC_PARKS_API_BASE_URL=https://bcparks.api.gov.bc.ca/api
OSM_EXTRACT_FILE=
# Ranked gap filling uses Overpass; deployments may provide their own endpoint.
# Optional comma-separated endpoint rotation for the targeted OSM gap-fill worker.
OVERPASS_API_URLS=https://overpass-api.de/api/interpreter,https://overpass.private.coffee/api/interpreter
OVERPASS_GAP_BATCH_SIZE=1
OSM_GAP_FILL_ENABLED=true
OVERTURE_RELEASE=
OVERTURE_PYTHON=python
LOCATION_MATCH_AUTOMATIC_THRESHOLD=0.90
LOCATION_MATCH_REVIEW_THRESHOLD=0.62
LOCATION_MATCH_MAX_DISTANCE_METERS=50000
LOCATION_REFRESH_CRON=0 7 * * 1
LOCATION_MONTHLY_CRON=0 8 1 * *
FORECAST_MODEL_PATH=./config/models/current.json
FORECAST_V2_MODEL_PATH=./config/models/v2.json
FORECAST_V3_MODEL_PATH=./config/models/v3.json
FORECAST_MODEL_MODE=v3-shadow
MONTHLY_FORECAST_MODEL_PATH=./config/models/monthly.json
FORECAST_FORCE_ALL=false
FORECAST_CACHED_WEATHER_MAX_DISTANCE_KM=500
FORECAST_OPEN_METEO_MAX_ATTEMPTS=10
FORECAST_RETENTION_DAYS=1
FORECAST_FAILED_RETENTION_DAYS=2
MONTHLY_FORECAST_RETENTION_DAYS=550
WEATHER_HISTORY_RETENTION_DAYS=90
RAW_WEATHER_RETENTION_DAYS=3
# Trusted proxy handling. Leave 0 unless the app is behind exactly this many proxies.
TRUST_PROXY_HOPS=0
REPORT_COMMENT_EDIT_HOURS=24
# Command-only: promotes an existing verified account during db:seed.
SEED_ADMIN_EMAIL=
BOT_PROTECTION_PROVIDER=none
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
